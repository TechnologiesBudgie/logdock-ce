# ═══════════════════════════════════════════════════════════════════
#  LogDock Community Edition Environment Configuration
#  Copy to .env and fill in values. NEVER commit secrets to git.
# ═══════════════════════════════════════════════════════════════════

# ─── Required in production ──────────────────────────────────────
# Generate with: just gen-secret  OR  openssl rand -hex 32
LOGDOCK_JWT_SECRET=change-me-now-use-openssl-rand-hex-32

# Master key for AES-256-GCM credential encryption (webhooks)
# Generate with: just gen-master-key  OR  openssl rand -hex 32
LOGDOCK_MASTER_KEY=change-me-now-use-openssl-rand-hex-32

# Admin password (change immediately after first login)
LOGDOCK_ADMIN_PASSWORD=admin

# Set to "production" to enforce security checks at startup
LOGDOCK_ENV=development

# ─── Server ───────────────────────────────────────────────────────
LOGDOCK_HTTP_ADDR=:2514
LOGDOCK_OTLP_GRPC_ADDR=:4317
LOGDOCK_OTLP_HTTP_ADDR=:4318
LOGDOCK_SYSLOG_TCP_ADDR=:5140
LOGDOCK_SYSLOG_UDP_ADDR=:5140

# ─── TLS (optional) ───────────────────────────────────────────────
# LOGDOCK_TLS_CERT_FILE=/etc/logdock/tls/cert.pem
# LOGDOCK_TLS_KEY_FILE=/etc/logdock/tls/key.pem

# ─── Storage ──────────────────────────────────────────────────────
LOGDOCK_DATA_DIR=./data
# LOGDOCK_STORAGE_ENGINE=fs       # fs | lvm | zfs
# LOGDOCK_LVM_VG=vg_logdock       # LVM volume group (when ENGINE=lvm)
# LOGDOCK_ZFS_POOL=tank           # ZFS pool name (when ENGINE=zfs)

# ─── Webhooks (set via Settings UI — encrypted automatically) ─────
# Can also be set here (encrypted on first server start):
# LOGDOCK_WEBHOOK_ALERT_URL=https://hooks.example.com/alerts
# LOGDOCK_WEBHOOK_SLACK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
